# Database
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=ims
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ims

# AI — Mistral EU API (GDPR-compliant, EU-gehost)
# Andere opties: OpenRouter (https://openrouter.ai/api/v1) of Ollama lokaal (http://localhost:11434/v1)
AI_API_BASE=https://api.mistral.ai/v1
AI_API_KEY=
AI_MODEL_NAME=mistral-small-latest
AI_EMBEDDING_MODEL=mistral-embed
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3

# Auth
JWT_SECRET_KEY=changeme-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
ENVIRONMENT=development
DEFAULT_TENANT_ID=default
ALLOWED_ORIGINS=http://localhost:3000

# Observability (optional)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=
