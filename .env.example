# IMS Environment Configuration
# Copy this to .env and fill in your values

# PostgreSQL Database
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=<your-secure-password>
POSTGRES_DB=ims

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@your-domain.com
PGADMIN_DEFAULT_PASSWORD=<your-secure-password>

# AI Configuration
AI_API_BASE=http://ollama:11434/v1
AI_MODEL=mistral

# Frontend
API_URL=http://api:8000

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
